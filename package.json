{
  "name": "sanity-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:staging": "dotenv -e .env.staging -- next dev -p 3001",
    "dev:prod": "dotenv -e .env.production -- next dev -p 3000",
    "promote": "sanity dataset export staging staging-backup.tar.gz && sanity dataset import staging-backup.tar.gz production --replace",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@portabletext/react": "^3.2.0",
    "@sanity/image-url": "^1.1.0",
    "next": "^15.1.0",
    "next-sanity": "^9.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}