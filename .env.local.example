# Get these from https://sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=2dt1cxx4
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: only needed for private datasets or live previews
# SANITY_API_TOKEN=your_token_here

# Webhook secret — create at sanity.io/manage → API → Webhooks, add to Vercel env vars
# Enables instant cache invalidation when you publish (no 60s wait)
# SANITY_REVALIDATE_SECRET=your_webhook_secret
